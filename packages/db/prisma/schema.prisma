generator client {
  provider = "prisma-client-js"
}

generator pyclient {
  provider                    = "prisma-client-py"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  CHEF
  EMPLOYEE
  ACCOUNTANT
  VIEWER
}

enum InvoiceStatus {
  UPLOADED
  OCR_PROCESSING
  OCR_REVIEW
  APPROVED
  REJECTED
}

enum StockMovementType {
  PURCHASE
  PRODUCTION
  WASTE
  INVENTORY_ADJUSTMENT
  SALE
  TRANSFER
}

enum InventorySessionStatus {
  DRAFT
  COUNTING
  REVIEW
  VALIDATED
  CANCELLED
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String
  firstName      String
  lastName       String
  isActive       Boolean            @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  memberships    RestaurantMember[]
  employeeProfile EmployeeProfile?
  shifts         Shift[]
  planningSchedules PlanningSchedule[]
  auditLogs      AuditLog[]
  timeClockLogs  TimeClockLog[]
  timeClockCorrectionsMade TimeClockCorrectionLog[] @relation("TimeClockCorrectionByUser")
  timeClockCorrectionsFor  TimeClockCorrectionLog[] @relation("TimeClockCorrectionEmployee")
  uploadedSupplierInvoices  SupplierInvoice[] @relation("SupplierInvoiceUploadedBy")
}

model Restaurant {
  id                  String               @id @default(uuid())
  name                String
  legalName           String?
  siret               String?
  timezone            String               @default("Europe/Paris")
  currency            String               @default("EUR")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             RestaurantMember[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  invoices            SupplierInvoice[]
  invoiceTemplates    SupplierInvoiceTemplate[]
  inventoryItems      InventoryItem[]
  inventorySessions   InventoryCountSession[]
  recipes             Recipe[]
  subRecipes          SubRecipe[]
  productionBatches   ProductionBatch[]
  temperatureLogs     TemperatureLog[]
  temperatureEquipment TemperatureEquipment[]
  haccpTasks          HaccpTask[]
  foodLabels          FoodLabel[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  companySettings     CompanySettings?
  employeeProfiles    EmployeeProfile[]
  shifts              Shift[]
  planningSchedules   PlanningSchedule[]
  timeClockLogs       TimeClockLog[]
  timeClockCorrections TimeClockCorrectionLog[]
}

model RestaurantMember {
  id           String     @id @default(uuid())
  userId       String
  restaurantId String
  role         UserRole
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
}

model Supplier {
  id           String            @id @default(uuid())
  restaurantId String
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  categories   String[]          @default([])
  paymentTerms String?
  minimumOrder Decimal?          @db.Decimal(12, 2)
  rating       Decimal?          @db.Decimal(3, 2)
  leadTimeDays Int               @default(2)
  isActive     Boolean           @default(true)
  archivedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  purchaseOrders PurchaseOrder[]
  invoices     SupplierInvoice[]
  invoiceTemplates SupplierInvoiceTemplate[]
  inventoryItems InventoryItem[]
}

model SupplierInvoice {
  id             String        @id @default(uuid())
  restaurantId   String
  supplierId     String?
  uploadedByUserId String?
  templateId     String?
  number         String?
  status         InvoiceStatus @default(UPLOADED)
  originalName   String
  storedName     String?
  storagePath    String
  mimeType       String?
  fileSize       Int?
  ocrConfidence  Decimal?      @db.Decimal(5, 4)
  totalExcludingTax Decimal?   @db.Decimal(12, 2)
  totalIncludingTax Decimal?   @db.Decimal(12, 2)
  invoiceDate    DateTime?
  ocrPayload     Json?
  processedAt    DateTime?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id])
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  uploadedBy    User?         @relation("SupplierInvoiceUploadedBy", fields: [uploadedByUserId], references: [id])
  template     SupplierInvoiceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  lines          SupplierInvoiceLine[]
}

model SupplierInvoiceLine {
  id          String          @id @default(uuid())
  invoiceId   String
  inventoryItemId String?
  codeArticle String?
  label       String
  quantity    Decimal         @default(1) @db.Decimal(12, 3)
  unit        String           @default("piece")
  unitPrice   Decimal         @default(0) @db.Decimal(12, 4)
  total       Decimal         @default(0) @db.Decimal(12, 2)
  taxRate     Decimal?        @db.Decimal(5, 2)
  confidence  Decimal?        @db.Decimal(5, 4)
  createdAt   DateTime        @default(now())
  invoice     SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
}

model SupplierInvoiceTemplate {
  id              String     @id @default(uuid())
  restaurantId    String
  supplierId      String?
  name            String?
  numberPattern   String?
  keywordHints    Json?
  lineHints       Json?
  exampleRows     Json?
  notes           String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  supplier        Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  invoices        SupplierInvoice[]

  @@index([restaurantId, supplierId])
}

model InventoryItem {
  id             String          @id @default(uuid())
  restaurantId   String
  supplierId     String?
  sku            String?
  name           String
  category       String
  storageArea    String?
  unit           String
  quantityOnHand Decimal         @default(0) @db.Decimal(12, 3)
  reorderPoint   Decimal         @default(0) @db.Decimal(12, 3)
  averageCost    Decimal         @default(0) @db.Decimal(12, 4)
  allergens      String[]        @default([])
  autoAllergens  String[]        @default([])
  isActive       Boolean         @default(true)
  archivedAt     DateTime?
  lastCountedAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  movements      StockMovement[]
  countLines     InventoryCountLine[]
  invoiceLines   SupplierInvoiceLine[]
  recipeIngredients RecipeIngredient[]
  subRecipeIngredients SubRecipeIngredient[]
  productionConsumptions ProductionConsumption[]
  purchaseOrderLines PurchaseOrderLine[]
}

model PurchaseOrder {
  id           String     @id @default(uuid())
  restaurantId String
  supplierId   String
  number       String
  status       String     @default("DRAFT")
  orderedAt    DateTime   @default(now())
  sentAt       DateTime?
  receivedAt   DateTime?
  notes        String?
  totalAmount  Decimal    @default(0) @db.Decimal(12, 2)
  isArchived   Boolean    @default(false)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  supplier     Supplier   @relation(fields: [supplierId], references: [id])
  lines        PurchaseOrderLine[]

  @@unique([restaurantId, number])
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  inventoryItemId String
  itemName        String
  unit            String
  quantityOrdered Decimal       @db.Decimal(12, 3)
  quantityReceived Decimal      @default(0) @db.Decimal(12, 3)
  unitCost        Decimal?      @db.Decimal(12, 4)
  lineTotal       Decimal       @default(0) @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
}

model StockMovement {
  id              String            @id @default(uuid())
  inventoryItemId String
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  unitCost        Decimal?          @db.Decimal(12, 4)
  note            String?
  createdAt       DateTime          @default(now())
  item            InventoryItem     @relation(fields: [inventoryItemId], references: [id])
}

model InventoryCountSession {
  id           String                 @id @default(uuid())
  restaurantId String
  name         String
  status       InventorySessionStatus @default(DRAFT)
  storageArea  String?
  startedAt    DateTime?
  validatedAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  restaurant   Restaurant             @relation(fields: [restaurantId], references: [id])
  lines        InventoryCountLine[]
}

model InventoryCountLine {
  id              String                @id @default(uuid())
  sessionId       String
  inventoryItemId String
  expectedQty     Decimal               @default(0) @db.Decimal(12, 3)
  countedQty      Decimal?              @db.Decimal(12, 3)
  varianceQty     Decimal               @default(0) @db.Decimal(12, 3)
  note            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  session         InventoryCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item            InventoryItem         @relation(fields: [inventoryItemId], references: [id])

  @@unique([sessionId, inventoryItemId])
}

model Recipe {
  id             String             @id @default(uuid())
  restaurantId   String
  name           String
  category       String?
  portionYield   Decimal            @default(1) @db.Decimal(12, 3)
  sellingPrice   Decimal            @default(0) @db.Decimal(12, 2)
  foodCost       Decimal            @default(0) @db.Decimal(12, 2)
  costPerPortion Decimal            @default(0) @db.Decimal(12, 2)
  marginRate     Decimal            @default(0) @db.Decimal(8, 4)
  allergens      String[]           @default([])
  instructions   String?
  photoName      String?
  photoMimeType  String?
  photoPath      String?
  isActive       Boolean            @default(true)
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id])
  ingredients    RecipeIngredient[]
  productionBatches ProductionBatch[]
}

model SubRecipe {
  id             String                @id @default(uuid())
  restaurantId   String
  name           String
  category       String?
  batchUnit      String
  batchYield     Decimal               @db.Decimal(12, 3)
  cost           Decimal               @default(0) @db.Decimal(12, 2)
  costPerUnit    Decimal               @default(0) @db.Decimal(12, 4)
  allergens      String[]              @default([])
  instructions   String?
  isActive       Boolean               @default(true)
  archivedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  restaurant     Restaurant            @relation(fields: [restaurantId], references: [id])
  ingredients    SubRecipeIngredient[] @relation("SubRecipeIngredients")
  recipeUsages   RecipeIngredient[]    @relation("RecipeIngredientSubRecipe")
}

model RecipeIngredient {
  id                String         @id @default(uuid())
  recipeId          String
  inventoryItemId   String?
  subRecipeId       String?
  name              String
  quantity          Decimal        @db.Decimal(12, 3)
  unit              String
  unitCostSnapshot  Decimal        @default(0) @db.Decimal(12, 4)
  wasteRate         Decimal        @default(0) @db.Decimal(8, 4)
  totalCost         Decimal        @default(0) @db.Decimal(12, 2)
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  recipe            Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  subRecipe         SubRecipe?     @relation("RecipeIngredientSubRecipe", fields: [subRecipeId], references: [id], onDelete: SetNull)
}

model SubRecipeIngredient {
  id                String         @id @default(uuid())
  subRecipeId       String
  inventoryItemId   String?
  name              String
  quantity          Decimal        @db.Decimal(12, 3)
  unit              String
  unitCostSnapshot  Decimal        @default(0) @db.Decimal(12, 4)
  wasteRate         Decimal        @default(0) @db.Decimal(8, 4)
  totalCost         Decimal        @default(0) @db.Decimal(12, 2)
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subRecipe         SubRecipe      @relation("SubRecipeIngredients", fields: [subRecipeId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
}

model TemperatureLog {
  id           String     @id @default(uuid())
  restaurantId String
  equipmentId  String?
  equipment    String
  equipmentType String?
  valueCelsius  Decimal    @db.Decimal(5, 2)
  minCelsius    Decimal?   @db.Decimal(5, 2)
  maxCelsius    Decimal?   @db.Decimal(5, 2)
  service      String?
  checkDate    DateTime?
  recordedAt   DateTime   @default(now())
  isCompliant  Boolean
  correctiveAction String?
  note         String?
  isArchived   Boolean    @default(false)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  equipmentRef TemperatureEquipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
}

model TemperatureEquipment {
  id           String     @id @default(uuid())
  restaurantId String
  name         String
  type         String
  minCelsius   Decimal?   @db.Decimal(5, 2)
  maxCelsius   Decimal?   @db.Decimal(5, 2)
  isActive     Boolean    @default(true)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  logs         TemperatureLog[]

  @@unique([restaurantId, name])
}

model HaccpTask {
  id               String     @id @default(uuid())
  restaurantId     String
  title            String
  category         String
  frequency        String
  templateKey      String?
  scheduledForDate DateTime?
  scheduledService String?
  isRecurring      Boolean    @default(false)
  status           String     @default("TODO")
  dueAt            DateTime?
  completedAt      DateTime?
  completedBy      String?
  completedByUserId String?
  correctiveAction String?
  notes            String?
  isArchived       Boolean    @default(false)
  archivedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  validations      HaccpTaskValidation[]

  @@unique([restaurantId, templateKey, scheduledForDate, scheduledService])
}

model HaccpTaskValidation {
  id               String    @id @default(uuid())
  taskId           String
  userId           String?
  responsible      String
  completedAt      DateTime  @default(now())
  comment          String?
  correctiveAction String?
  status           String    @default("DONE")
  createdAt        DateTime  @default(now())
  task             HaccpTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model FoodLabel {
  id           String     @id @default(uuid())
  restaurantId String
  productionBatchId String?
  title        String
  itemName     String
  batchNumber  String?
  quantity     Decimal?   @db.Decimal(12, 3)
  unit         String?
  preparedAt   DateTime
  expiresAt    DateTime
  storageArea  String?
  allergens    String[]   @default([])
  notes        String?
  status       String     @default("ACTIVE")
  sourceType   String     @default("FREE")
  sourceId     String?
  expiryKind   String     @default("DLC")
  conservationTemperature String?
  isArchived   Boolean    @default(false)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  productionBatch ProductionBatch? @relation(fields: [productionBatchId], references: [id], onDelete: SetNull)
}

model ProductionBatch {
  id           String     @id @default(uuid())
  restaurantId String
  recipeId     String
  lotNumber    String
  recipeName   String
  quantityProduced Decimal @db.Decimal(12, 3)
  unit         String     @default("portion")
  preparedAt   DateTime
  expiresAt    DateTime
  shelfLifeHours Int      @default(72)
  storageArea  String?
  conservationTemperature String?
  allergens    String[]   @default([])
  totalIngredientCost Decimal @default(0) @db.Decimal(12, 2)
  wasteQuantity Decimal   @default(0) @db.Decimal(12, 3)
  wasteReason  String?
  notes        String?
  status       String     @default("ACTIVE")
  isArchived   Boolean    @default(false)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  consumptions ProductionConsumption[]
  labels       FoodLabel[]

  @@unique([restaurantId, lotNumber])
}

model ProductionConsumption {
  id           String     @id @default(uuid())
  productionBatchId String
  inventoryItemId String
  ingredientName String
  quantityConsumed Decimal @db.Decimal(12, 3)
  unit         String
  unitCostSnapshot Decimal @default(0) @db.Decimal(12, 4)
  totalCost    Decimal    @default(0) @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  batch        ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
}

model TimeClockLog {
  id          String   @id @default(uuid())
  restaurantId String
  userId      String
  clockIn     DateTime
  clockOut    DateTime?
  source      String   @default("web")
  isArchived  Boolean  @default(false)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  corrections TimeClockCorrectionLog[]
}

model EmployeeProfile {
  id           String     @id @default(uuid())
  restaurantId String
  userId       String     @unique
  position     String
  phone        String?
  isActive     Boolean    @default(true)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}

model Shift {
  id           String     @id @default(uuid())
  restaurantId String
  userId       String
  startAt      DateTime
  endAt        DateTime
  breakMinutes Int        @default(0)
  position     String
  comment      String?
  isArchived   Boolean    @default(false)
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([restaurantId, userId, startAt])
}

model PlanningSchedule {
  id                  String               @id @default(uuid())
  restaurantId        String
  userId              String
  weekStart           DateTime
  weeklyTargetMinutes Int                  @default(0)
  position            String
  comment             String?
  isDayOff            Boolean              @default(false)
  isArchived          Boolean              @default(false)
  archivedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  days                PlanningScheduleDay[]

  @@unique([restaurantId, userId, weekStart])
}

model PlanningScheduleDay {
  id                String            @id @default(uuid())
  planningScheduleId String
  weekday           Int
  morningStart      String?
  morningEnd        String?
  breakMinutes      Int               @default(0)
  eveningStart      String?
  eveningEnd        String?
  isDayOff          Boolean           @default(false)
  comment           String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  schedule          PlanningSchedule  @relation(fields: [planningScheduleId], references: [id], onDelete: Cascade)

  @@unique([planningScheduleId, weekday])
}

model TimeClockCorrectionLog {
  id               String     @id @default(uuid())
  restaurantId     String
  timeClockLogId   String?
  employeeUserId   String
  correctedByUserId String
  reason           String
  note             String?
  originalClockIn  DateTime?
  originalClockOut DateTime?
  correctedClockIn DateTime?
  correctedClockOut DateTime?
  createdAt        DateTime   @default(now())
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  timeClockLog     TimeClockLog? @relation(fields: [timeClockLogId], references: [id], onDelete: SetNull)
  employee         User       @relation("TimeClockCorrectionEmployee", fields: [employeeUserId], references: [id])
  correctedBy      User       @relation("TimeClockCorrectionByUser", fields: [correctedByUserId], references: [id])
}

model Notification {
  id           String     @id @default(uuid())
  restaurantId String
  title        String
  body         String
  level        String     @default("info")
  readAt       DateTime?
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model AuditLog {
  id           String     @id @default(uuid())
  restaurantId String?
  userId       String?
  action       String
  entity       String
  entityId     String?
  metadata     Json?
  createdAt    DateTime   @default(now())
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  user         User?      @relation(fields: [userId], references: [id])
}

model CompanySettings {
  id           String     @id @default(uuid())
  restaurantId String     @unique
  brandName    String
  invoiceEmail String?
  haccpManager String?
  settings     Json       @default("{}")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}
